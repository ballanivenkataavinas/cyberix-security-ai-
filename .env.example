# API Configuration - Groq API (Free Tier)
GROQ_API_KEY=your_groq_api_key_here

# Security
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database - SQLite for local, PostgreSQL for production
DATABASE_URL=sqlite:///./cyberix.db
# Production PostgreSQL: postgresql://username:password@host:port/database

# CORS - Add your Render URL after deployment
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Environment
ENVIRONMENT=development
